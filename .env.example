# Copy this file to .env and fill in real values locally.
# Do not commit .env because it can contain secrets.

MONGO_URI=mongodb://localhost:27017/doctor-appointment
JWT_SECRET=your_jwt_secret_key_here
PORT=5000
NODE_ENV=development

# Optional local admin seed values used by src/server.js
ADMIN_NAME=Hospital Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
